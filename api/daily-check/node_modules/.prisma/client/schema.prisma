generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Tarefa {
  id           Int      @id @default(autoincrement())
  nome         String
  descricao    String
  data_inicio  DateTime
  data_termino DateTime
  imagem       String?
  data_criacao DateTime @default(now())
}
